[Unit]
Description=vjt-claude "Ridateci tsk" petition signature sidecar (!firma)
Documentation=https://github.com/vjt/claude-ircbot
After=default.target

[Service]
Type=simple
WorkingDirectory=/home/vjt/code/IRC/vjt-claude
ExecStart=/usr/bin/python3 -u /home/vjt/code/IRC/vjt-claude/firma_counter.py
Restart=on-failure
RestartSec=5
StandardOutput=append:/home/vjt/code/IRC/vjt-claude/firma_counter.log
StandardError=inherit

[Install]
WantedBy=default.target
